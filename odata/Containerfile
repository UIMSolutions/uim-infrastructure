FROM docker.io/dlanguage/dmd:2.111.0 AS builder

WORKDIR /app
COPY dub.sdl .
COPY source/ source/

RUN dub build --build=release

FROM docker.io/debian:bookworm-slim

RUN apt-get update && apt-get install -y libphobos2-ldc-shared98 || true && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /app/uim-odata-service .

EXPOSE 8080

CMD ["./uim-odata-service"]
